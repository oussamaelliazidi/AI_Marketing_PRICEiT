# ─── Required ────────────────────────────────────────────────────────────────

# Anthropic API key (for editorial brain, content transform, expert panel)
ANTHROPIC_API_KEY=your-anthropic-api-key

# ─── Content Ops Config ──────────────────────────────────────────────────────

CONTENT_OPS_DATA_DIR=./data

EDITORIAL_BRAIN_MODEL=claude-opus-4-5

# ─── Voice & Style ────────────────────────────────────────────────────────────

VOICE_CONFIG_FILE=./config/voice.md
STYLE_GUIDE_FILE=./config/style-guide.md

# ─── Quote Mining (optional) ─────────────────────────────────────────────────

# QUOTE_MINING_FEEDS_FILE=./config/feeds.json
# QUOTE_MINING_NOTES_DIR=./notes/
# QUOTE_MINING_SPEAKER=Your Name
