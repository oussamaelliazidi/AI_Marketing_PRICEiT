# ─── Required API Keys ───────────────────────────────────────────────────────

# HubSpot API key (for Deal Resurrector + Suppression Pipeline CRM check)
# Get one: HubSpot → Settings → Integrations → Private Apps
HUBSPOT_API_KEY=your-hubspot-private-app-token

# Instantly API key (for RB2B Router + Suppression Pipeline)
# Get one: Instantly.ai → Settings → API
INSTANTLY_API_KEY=your-instantly-api-key

# Brave Search API key (for Trigger Prospector)
# Get one: https://api.search.brave.com/
BRAVE_API_KEY=your-brave-search-api-key

# ─── Optional: Database (for ICP Learning Analyzer) ─────────────────────────

# Supabase PostgreSQL connection string (priceit-beta-waitlist project)
DATABASE_URL=postgresql://postgres:[password]@db.yyaonzukkomxqrafkgve.supabase.co:5432/postgres

# ─── PRICEIT Company Info ────────────────────────────────────────────────────

YOUR_COMPANY_NAME=PRICEIT
YOUR_SENDER_NAME=Your Name
YOUR_SENDER_TITLE=Founder
YOUR_VALUE_PROP=PRICEIT helps contractors and construction firms price every job accurately in under 2 minutes — no spreadsheets, no guesswork, no lost margin.

# ─── Pipeline Configuration ─────────────────────────────────────────────────

DEFAULT_SOURCE_SITE=priceit.io

# Minimum intent score to process visitors (0-100)
MIN_INTENT_SCORE=50

# PRICEIT ICP: target firms with 1-500 employees (small contractors + large firms)
ICP_MIN_COMPANY_SIZE=1

# Company dedup window in days
COMPANY_DEDUP_WINDOW_DAYS=7

# HubSpot API rate limit delay
HUBSPOT_RATE_DELAY=1.5

# Campaign routing (replace with your Instantly campaign UUIDs once set up)
CAMPAIGN_SMALL_CONTRACTOR=SmallContractor-BetaOutreach
CAMPAIGN_LARGE_FIRM=LargeFirm-BetaOutreach
CAMPAIGN_AGENCY=Agency-Default
CAMPAIGN_GENERAL=General-Default
